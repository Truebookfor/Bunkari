# ============================================================================
# CROCHET STORE — Environment Variables
# Inko copy karke `.env.local` banao aur asli values daalo.
# .env.local kabhi git me commit mat karna (already .gitignored).
# ============================================================================

# ---- Supabase (Database) ----
# Supabase dashboard > Project Settings > API se milega
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key SIRF server par use hota hai (admin writes). Kabhi public mat karna.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Razorpay (Payments) ----
# Razorpay dashboard > Settings > API Keys se milega
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ---- Admin ----
# Admin dashboard kholne ke liye password
ADMIN_PASSWORD=

# ---- Site ----
# Production URL (sitemap/SEO ke liye). Dev me khali chhod sakte ho.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
